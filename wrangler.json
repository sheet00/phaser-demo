/**
 * Cloudflare Workers (Assets) 用 Wrangler 設定
 */
{
  "$schema": "src/node_modules/wrangler/config-schema.json",
  "name": "phaser-demo",
  "compatibility_date": "2024-09-19",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./src/dist"
  },
  "observability": {
    "enabled": true
  }
}
